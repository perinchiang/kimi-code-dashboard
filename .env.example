# Kimi Code Dashboard environment variables
# Copy this file to .env and fill in your API key.
KIMI_API_KEY=sk-your-kimi-api-key-here

# Kimi Web launch preferences (optional)
KIMI_WEB_PORT=5494
KIMI_WEB_HOST=127.0.0.1
KIMI_WEB_KEEP_ALIVE=1
KIMI_WEB_BYPASS_AUTH=0
# KIMI_WEB_ALLOWED_HOSTS=your-domain.com,another-domain.com
# KIMI_WEB_PUBLIC_URL=http://your-domain.com,https://another-domain.com
